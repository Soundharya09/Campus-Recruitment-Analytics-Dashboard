      <column caption='Aptitude Skills Score' datatype='real' name='[Aptitude_Skills_Score]' role='measure' type='quantitative' />
      <column caption='Placement Rate' datatype='real' default-format='p0.00%' name='[Calculation_0515163097227265]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Placed]) / COUNT([Student_Id])' />
      </column>
      <column caption='SSC Band' datatype='string' name='[Calculation_0515163113721858]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [SSC_Percentage] &gt;= 85 THEN &apos;Excellent&apos;&#13;&#10;ELSEIF  [SSC_Percentage] &gt;= 70 THEN &apos;Good&apos;&#13;&#10;ELSE &apos;Average&apos; &#13;&#10;END' />
      </column>
      <column caption='Aptitude Band' datatype='string' name='[Calculation_0515163122126851]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Aptitude_Skills_Score] &gt;= 80 THEN &apos;High&apos;&#13;&#10;ELSEIF [Aptitude_Skills_Score] &gt;=60 THEN &apos;Medium&apos;&#13;&#10;ELSE &apos;Low&apos;&#13;&#10;END' />
      </column>
      <column caption='Internship Band' datatype='string' name='[Calculation_0515163135811588]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Internships] &gt;= 3 THEN &apos;3+&apos;&#13;&#10;ELSEIF [Internships] = 2 THEN &apos;2&apos;&#13;&#10;ELSEIF [Internships] = 1 THEN &apos;1&apos;&#13;&#10;ELSE &apos;0&apos;&#13;&#10;END' />
      </column>
      <column caption='Experience Band' datatype='string' name='[Calculation_0515163138342917]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Work_Experience_Months] = 0 THEN &apos;Fresher&apos;&#13;&#10;ELSEIF [Work_Experience_Months] &lt;= 12 THEN &apos;Upto 1 Year&apos;&#13;&#10;ELSEIF [Work_Experience_Months] &lt;= 24 THEN &apos;1-2 Years&apos;&#13;&#10;ELSE &apos;2+ Years&apos;&#13;&#10;END' />
      </column>
      <column caption='Salary Band' datatype='string' name='[Calculation_0813131046879232]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Salary_LPA] &lt; 8 THEN &quot;Below 8 LPA&quot;&#13;&#10;ELSEIF [Salary_LPA] &lt; 12 THEN &quot;8-12 LPA&quot;&#13;&#10;ELSEIF [Salary_LPA] &lt; 15 THEN &quot;12-15 LPA&quot;&#13;&#10;ELSE &quot;15+ LPA&quot;&#13;&#10;END' />
      </column>
      <column caption='Salary Category' datatype='string' name='[Calculation_0813131051773953]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Salary_LPA] &gt;= [Parameters].[Salary LPA Parameter] THEN &quot;High Salary&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
